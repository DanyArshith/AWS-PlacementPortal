{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/nginx/access.log",
            "log_group_name": "placement-portal-nginx-access",
            "log_stream_name": "{hostname}",
            "retention_in_days": 14
          },
          {
            "file_path": "/var/log/nginx/error.log",
            "log_group_name": "placement-portal-nginx-error",
            "log_stream_name": "{hostname}",
            "retention_in_days": 14
          },
          {
            "file_path": "/var/www/placement-portal/backend/logs/app.log",
            "log_group_name": "placement-portal-backend-app",
            "log_stream_name": "{hostname}",
            "retention_in_days": 14
          },
          {
            "file_path": "/var/www/placement-portal/backend/logs/error.log",
            "log_group_name": "placement-portal-backend-error",
            "log_stream_name": "{hostname}",
            "retention_in_days": 14
          },
          {
            "file_path": "/var/www/placement-portal/backend/logs/pm2_err.log",
            "log_group_name": "placement-portal-backend-pm2-error",
            "log_stream_name": "{hostname}",
            "retention_in_days": 14
          }
        ]
      }
    }
  }
}
